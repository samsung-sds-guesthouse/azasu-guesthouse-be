<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.samsung.azasuguesthouse.guest.dao.RoomMapper">

    <select id="findById" resultType="com.samsung.azasuguesthouse.entity.room.Room">
        SELECT
            id,
            room_name AS roomName,
            capacity,
            price,
            description,
            policy,
            picture,
            status,
            created_at AS createdAt,
            updated_at AS updatedAt
        FROM rooms
        WHERE id = #{id};
    </select>


</mapper>
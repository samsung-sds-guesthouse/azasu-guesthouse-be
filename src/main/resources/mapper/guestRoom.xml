<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.samsung.azasuguesthouse.guest.dao.RoomMapper">

    <resultMap id="RoomResultMap" type="com.samsung.azasuguesthouse.guest.dto.RoomDto">
        <id property="roomId" column="id" />
        <result property="roomName" column="room_name" />
        <result property="price" column="price" />
        <result property="capacity" column="capacity" />
        <result property="picture" column="picture" />
        <result property="description" column="description" />
        <result property="policy" column="policy" />
    </resultMap>

    <select id="findAllRooms" resultMap="RoomResultMap">
        SELECT * FROM rooms WHERE status = 'ACTIVE';
    </select>

    <select id="findById" resultType="com.samsung.azasuguesthouse.guest.dto.RoomDto">
        SELECT
            id,
            room_name AS roomName,
            capacity,
            price,
            description,
            policy,
            picture,
            status,
            created_at AS createdAt,
            updated_at AS updatedAt
        FROM rooms
        WHERE id = #{id};
    </select>


</mapper>